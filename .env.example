# Copy this file to .env and fill in your real keys
# NEVER commit .env to Git

# Anthropic (LLM brain) - https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NewsAPI (financial headlines) - https://newsapi.org
NEWS_API_KEY=your_news_api_key_here

# Alpaca (paper trading) - https://alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Agent config
WATCHLIST=AAPL,MSFT,BTC-USD,ETH-USD
RUN_INTERVAL_MINUTES=60
INITIAL_CASH_BALANCE=10000.00
